{
    "configurations": [
        {
            "name": "MacOS",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE"
            ],
            "compilerPath": "/usr/bin/clang++",
            "intelliSenseMode": "macos-gcc-arm64",
            "cppStandard": "c++26",
            "cStandard": "c23",
            "recursiveIncludes": {
                "priority": "afterSystemIncludes",
                "reduce": "default"
            }
        }
    ],
    "version": 4
}